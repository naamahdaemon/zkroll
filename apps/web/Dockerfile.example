FROM node:20-bookworm-slim AS build
WORKDIR /app

ARG VITE_API_URL
ARG VITE_ONCHAIN_ENABLED
ARG VITE_FEE_NANOMINA
ARG VITE_WALLET_RESPONSE_TIMEOUT_MS
ARG VITE_REFUND_TIMEOUT_SLOTS
ARG VITE_O1JS_BROWSER_CACHE_ENABLED
ARG VITE_TX_POLL_INTERVAL_MS
ARG VITE_SLOT_POLL_INTERVAL_MS
ARG VITE_WALLETCONNECT_PROJECT_ID
ARG VITE_MIN_JOIN_DEADLINE_MARGIN_SLOTS
ARG VITE_ZEKO_MIN_JOIN_DEADLINE_MARGIN_SLOTS
ARG VITE_PROVER_MODE
ARG VITE_SERVER_PROVER_POLL_MS
ARG VITE_SERVER_PROVER_WALLET_DELAY_MS
ARG VITE_ADMIN_PUBLIC_KEY
ARG VITE_FIREBASE_API_KEY
ARG VITE_FIREBASE_AUTH_DOMAIN
ARG VITE_FIREBASE_PROJECT_ID
ARG VITE_FIREBASE_MESSAGING_SENDER_ID
ARG VITE_FIREBASE_APP_ID
ARG VITE_FIREBASE_VAPID_KEY

ENV VITE_API_URL=$VITE_API_URL
ENV VITE_ONCHAIN_ENABLED=$VITE_ONCHAIN_ENABLED
ENV VITE_FEE_NANOMINA=$VITE_FEE_NANOMINA
ENV VITE_WALLET_RESPONSE_TIMEOUT_MS=$VITE_WALLET_RESPONSE_TIMEOUT_MS
ENV VITE_REFUND_TIMEOUT_SLOTS=$VITE_REFUND_TIMEOUT_SLOTS
ENV VITE_O1JS_BROWSER_CACHE_ENABLED=$VITE_O1JS_BROWSER_CACHE_ENABLED
ENV VITE_TX_POLL_INTERVAL_MS=$VITE_TX_POLL_INTERVAL_MS
ENV VITE_SLOT_POLL_INTERVAL_MS=$VITE_SLOT_POLL_INTERVAL_MS
ENV VITE_WALLETCONNECT_PROJECT_ID=$VITE_WALLETCONNECT_PROJECT_ID
ENV VITE_MIN_JOIN_DEADLINE_MARGIN_SLOTS=$VITE_MIN_JOIN_DEADLINE_MARGIN_SLOTS
ENV VITE_ZEKO_MIN_JOIN_DEADLINE_MARGIN_SLOTS=$VITE_ZEKO_MIN_JOIN_DEADLINE_MARGIN_SLOTS
ENV VITE_PROVER_MODE=$VITE_PROVER_MODE
ENV VITE_SERVER_PROVER_POLL_MS=$VITE_SERVER_PROVER_POLL_MS
ENV VITE_SERVER_PROVER_WALLET_DELAY_MS=$VITE_SERVER_PROVER_WALLET_DELAY_MS
ENV VITE_ADMIN_PUBLIC_KEY=$VITE_ADMIN_PUBLIC_KEY
ENV VITE_FIREBASE_API_KEY=$VITE_FIREBASE_API_KEY
ENV VITE_FIREBASE_AUTH_DOMAIN=$VITE_FIREBASE_AUTH_DOMAIN
ENV VITE_FIREBASE_PROJECT_ID=$VITE_FIREBASE_PROJECT_ID
ENV VITE_FIREBASE_MESSAGING_SENDER_ID=$VITE_FIREBASE_MESSAGING_SENDER_ID
ENV VITE_FIREBASE_APP_ID=$VITE_FIREBASE_APP_ID
ENV VITE_FIREBASE_VAPID_KEY=$VITE_FIREBASE_VAPID_KEY

COPY package*.json ./
COPY apps/web/package.json apps/web/package.json
COPY packages/shared/package.json packages/shared/package.json
COPY packages/contracts/package.json packages/contracts/package.json
RUN npm ci

COPY . .
RUN npm run build --workspace @zkroll/shared
RUN npm run build --workspace @zkroll/contracts
RUN npm run build --workspace @zkroll/web

FROM nginx:1.27-alpine
COPY --from=build /app/apps/web/dist /usr/share/nginx/html
COPY deploy/nginx/web.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
