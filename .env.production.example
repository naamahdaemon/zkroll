# Public domain and certificates
DOMAIN=zkroll.example.com
LETSENCRYPT_EMAIL=admin@example.com

# API persistence and public origin
ZKROLL_DB_PATH=/data/zkroll-mainnet.db
ZKROLL_WEB_ORIGIN=https://zkroll.example.com

# Chain/indexer reads
ZKROLL_CURRENT_SLOT_CACHE_MS=60000
ZKROLL_ZKAPP_STATE_CACHE_MS=60000
ZKROLL_TX_STATUS_SCAN_BLOCKS=50
ZKROLL_CHAIN_REQUEST_TIMEOUT_MS=20000
ZKROLL_ZEKO_SLOT_SOURCE_NETWORK=devnet

# Prover mode
# client: browser proving, no server prover required
# server: web sends proving jobs to the API; production should set ZKROLL_PROVER_URL
ZKROLL_PROVER_MODE=server
ZKROLL_PROVER_URL=http://prover:4001
ZKROLL_PROVER_REQUEST_TIMEOUT_MS=30000
ZKROLL_PROVER_DEBUG=false
ZKROLL_PROVER_WORKERS=1
ZKROLL_PROVER_FEE_NANOMINA=100000000

# Admin wallet allowed to access server-prover maintenance actions
ZKROLL_ADMIN_PUBLIC_KEY=

# Web build-time configuration
VITE_API_URL=https://zkroll.example.com/api
VITE_ONCHAIN_ENABLED=true
VITE_PROVER_MODE=server
VITE_SERVER_PROVER_POLL_MS=1500
VITE_SERVER_PROVER_WALLET_DELAY_MS=2500
VITE_FEE_NANOMINA=100000000
VITE_WALLET_RESPONSE_TIMEOUT_MS=120000
VITE_REFUND_TIMEOUT_SLOTS=120
VITE_O1JS_BROWSER_CACHE_ENABLED=false
VITE_TX_POLL_INTERVAL_MS=60000
VITE_SLOT_POLL_INTERVAL_MS=60000
VITE_WALLETCONNECT_PROJECT_ID=
VITE_MIN_JOIN_DEADLINE_MARGIN_SLOTS=20
VITE_ZEKO_MIN_JOIN_DEADLINE_MARGIN_SLOTS=30
VITE_ADMIN_PUBLIC_KEY=

# Firebase push notifications are optional. Leave empty to disable push.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# Legacy global-root variables. Do not set these for the per-game zkApp architecture.
# Keeping them empty here documents that they are obsolete and should not be
# referenced from docker-compose.prod.yml.
ZKROLL_CONTRACT_ADDRESS=
ZKROLL_ONCHAIN_ROOT_CACHE_MS=
VITE_ZKROLL_CONTRACT_ADDRESS=
ZKROLL_PROVER_BACKEND=
